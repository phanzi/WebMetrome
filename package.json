{
  "name": "syncron",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "author": "phanzi",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently 'bun run dev:vite' 'bun run dev:server'",
    "dev:vite": "vite dev",
    "dev:server": "APP_ENV=development bun --watch server/index.ts",
    "build": "bun run build:vite && bun run build:server",
    "build:vite": "vite build",
    "build:server": "bun build server/index.ts --compile --outfile=out/server",
    "start": "./out/server",
    "format": "prettier --write .",
    "lint": "eslint .",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "check": "bun run lint && bun run test && bun run build",
    "docker:build": "docker buildx build --platform linux/amd64 -t registry.ohjimin.com/$npm_package_name:$npm_package_version .",
    "docker:push": "docker push registry.ohjimin.com/$npm_package_name:$npm_package_version"
  },
  "dependencies": {
    "@elysiajs/eden": "^1.4.0",
    "@elysiajs/static": "^1.4.0",
    "@vitejs/plugin-react": "^6.0.1",
    "elysia": "^1.4.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "vite": "^8.0.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.2.2",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/bun": "^1.3.8",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@xeonlink/prettier-plugin-organize-attributes": "^1.1.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "prettier-plugin-curly": "^0.4.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "prettier-plugin-tailwindcss-canonical-classes": "^0.1.4",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1"
  }
}
