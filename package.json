{
  "name": "syncron",
  "version": "0.10.1",
  "private": false,
  "type": "module",
  "author": "phanzi",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently \"vite dev\" \"bun --watch server/index.ts\"",
    "build": "vite build && __PROD__=true bun build --env '__*__' server/index.ts --compile --outfile=dist/start && rm -rf dist/server",
    "start": "./dist/start",
    "format": "prettier --write .",
    "lint": "eslint .",
    "tsc": "tsc --noEmit",
    "assets:gen": "pwa-assets-generator --preset minimal-2023 public/favicon.svg",
    "docker:build": "docker buildx build --platform linux/amd64 -t registry.ohjimin.com/$npm_package_name:$npm_package_version .",
    "docker:push": "docker push registry.ohjimin.com/$npm_package_name:$npm_package_version"
  },
  "dependencies": {
    "@elysiajs/eden": "^1.4.0",
    "@elysiajs/static": "^1.4.0",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-router": "^1.168.24",
    "@tanstack/react-start": "^1.167.48",
    "@tanstack/router-plugin": "^1.167.22",
    "@vitejs/plugin-react": "^6.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "daisyui": "^5.5.19",
    "elysia": "^1.4.0",
    "es-toolkit": "^1.45.1",
    "immer": "^11.1.4",
    "lucide-react": "^1.8.0",
    "nanoid": "^5.1.7",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "uqr": "^0.1.3",
    "vite": "^8.0.7",
    "vite-plugin-svgr": "^5.2.0",
    "zod": "^4.1.12",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/bun": "^1.3.8",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vite-pwa/assets-generator": "^1.0.2",
    "@xeonlink/prettier-plugin-organize-attributes": "^1.1.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-config-flat-gitignore": "^2.3.0",
    "eslint-plugin-react-compiler": "^19.1.0-rc.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "prettier-plugin-curly": "^0.4.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "prettier-plugin-tailwindcss-canonical-classes": "^0.1.4",
    "sharp": "^0.34.5",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1"
  }
}
