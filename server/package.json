{
  "name": "web-sync-metronome",
  "version": "0.1.14",
  "private": false,
  "type": "module",
  "author": "phanzi",
  "license": "MIT",
  "scripts": {
    "server:dev": "node src/server.js",
    "client:dev": "vite --host --mode dev",
    "dev": "concurrently 'npm run client:dev' 'npm run server:dev'",
    "server:start": "node src/server.js",
    "client:start": "vite preview --host --mode prod",
    "start": "concurrently 'npm run client:start' 'npm run server:start'",
    "format": "prettier --write .",
    "build": "vite build --mode build",
    "lint": "eslint .",
    "docker:build": "docker buildx build --platform linux/amd64 -t registry.ohjimin.com/$npm_package_name:$npm_package_version .",
    "docker:push": "docker push registry.ohjimin.com/$npm_package_name:$npm_package_version",
    "docker:push:latest": "docker tag registry.ohjimin.com/$npm_package_name:$npm_package_version registry.ohjimin.com/$npm_package_name:latest && docker push registry.ohjimin.com/$npm_package_name:latest"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.2"
  }
}
